{
  "name": "@funnel/renderer",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI edge renderer. Cloudflare Worker that serves any published funnel JSON as a live HTML page worldwide in <5s, handles form submissions, A/B routing, AI disclosure, lead capture and server-side analytics.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"(no linter configured)\""
  },
  "dependencies": {
    "@funnel/db": "workspace:*",
    "@funnel/events": "workspace:*",
    "@funnel/shared": "workspace:*",
    "@funnel/ui": "workspace:*",
    "@neondatabase/serverless": "^0.10.1",
    "hono": "^4.6.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241004.0",
    "@funnel/tsconfig": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "miniflare": "^3.20241004.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
