# =============================================================================
# GoFunnelAI — single Next.js app, all env vars in ONE file.
# Copy to `.env` (local dev) or set as Railway service variables (production).
# =============================================================================

# ---- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@localhost:5432/funnel_ai"
DIRECT_DATABASE_URL="postgresql://user:pass@localhost:5432/funnel_ai"

# ---- Redis (BullMQ workers + caching) ---------------------------------------
REDIS_URL=""
# Set to 0 to skip starting BullMQ workers inside the web process
# (useful if you scale them as a separate Railway service).
ENABLE_EMBEDDED_WORKERS="1"

# ---- Auth (NextAuth v5, Google as sole identity provider) -------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# ---- API keys (issued to customers) -----------------------------------------
API_KEY_PEPPER=""

# ---- LLM providers ----------------------------------------------------------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ---- Image / Video generation -----------------------------------------------
REPLICATE_API_TOKEN=""
REPLICATE_WEBHOOK_SECRET=""
RUNWAY_API_KEY=""

# ---- Licensed-stock fallback (used when AI budget exhausted or free tier) ----
UNSPLASH_ACCESS_KEY=""
PEXELS_API_KEY=""

# ---- Voice (RevTry — SignalWire telephony) ----------------------------------
ELEVENLABS_API_KEY=""
REVTRY_API_KEY=""
SIGNALWIRE_PROJECT_ID=""
SIGNALWIRE_API_TOKEN=""
SIGNALWIRE_SPACE_URL=""
SIGNALWIRE_FROM_NUMBER=""

# ---- Payments — PRIMARY: PayPal, SECONDARY: Stripe --------------------------
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"
PAYPAL_PLAN_STARTER=""
PAYPAL_PLAN_GROWTH=""
PAYPAL_PLAN_AGENCY=""
NEXT_PUBLIC_PAYPAL_MANAGE_URL="https://www.paypal.com/myaccount/autopay/"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_API_VERSION="2026-02-25.clover"

# ---- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# ---- Storage (Cloudflare R2) ------------------------------------------------
GOFUNNELAI_DATA_DIR=""
RAILWAY_VOLUME_MOUNT_PATH=""
CLOUDFLARE_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="funnel-assets"
R2_PUBLIC_BASE_URL="https://cdn.gofunnelai.com"

# ---- Brand autofill ---------------------------------------------------------
CLEARBIT_API_KEY=""
WHOISXML_API_KEY=""

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ---- Ad platforms (OAuth + publishing) --------------------------------------
META_APP_ID=""
META_APP_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""

# ---- Feature flags ----------------------------------------------------------
LAUNCHDARKLY_SDK_KEY=""

# ---- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
