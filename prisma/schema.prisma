// GoFunnelAI canonical Prisma schema.
// Source of truth: docs/03-event-taxonomy-and-schemas.md (PART B).
// The accompanying migration in prisma/migrations/20260101000000_init/migration.sql
// installs all extensions, RLS policies, partitioning, triggers, and indexes that
// Prisma cannot express natively. Prisma schema and migration MUST stay in sync.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  extensions        = [pgcrypto, citext, btree_gin, pg_trgm, vector]
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

enum WorkspaceRole {
  owner
  admin
  editor
  analyst
  viewer
  billing

  @@map("workspace_role")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  paused
  canceled
  suspended

  @@map("subscription_status")
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible

  @@map("invoice_status")
}

enum LeadStatus {
  new
  contacted
  qualified
  disqualified
  booked
  converted
  closed

  @@map("lead_status")
}

enum CallOutcome {
  answered
  no_answer
  voicemail
  busy
  failed
  do_not_call

  @@map("call_outcome")
}

enum AssetType {
  page
  copy
  image
  video
  script
  email
  sms
  ad_creative
  form

  @@map("asset_type")
}

enum FunnelStatus {
  draft
  review
  live
  paused
  archived

  @@map("funnel_status")
}

enum PiiTier {
  P0
  P1
  P2
  P3

  @@map("pii_tier")
}

enum UserStatus {
  active
  deactivated
  deleted

  @@map("user_status")
}

enum WorkspaceStatus {
  active
  suspended
  closed

  @@map("workspace_status")
}

enum PaymentStatus {
  succeeded
  failed
  pending
  refunded
  partially_refunded

  @@map("payment_status")
}

enum BookingStatus {
  confirmed
  canceled
  completed
  no_show

  @@map("booking_status")
}

enum PublishedFunnelStatus {
  active
  paused
  archived

  @@map("published_funnel_status")
}

enum CustomDomainStatus {
  pending
  verifying
  verified
  active
  failed
  removed

  @@map("custom_domain_status")
}

enum SslStatus {
  pending_validation
  active
  failed
  unknown

  @@map("ssl_status")
}

// =====================================================================
// IDENTITY
// =====================================================================

model User {
  id              String     @id @default(dbgenerated("'usr_' || encode(gen_random_bytes(13), 'hex')"))
  // NextAuth / @auth/prisma-adapter canonical columns ----------------------
  name            String?
  email           String     @unique @db.Citext
  emailVerified   DateTime?  @map("email_verified") @db.Timestamptz(6)
  image           String?
  // Email + password credentials (Auth.js Credentials provider) -----------
  // OAuth-only users (e.g. Google) leave these NULL; password rows are only
  // written on email/password signup or password change.
  passwordHash    String?    @map("password_hash")
  passwordSetAt   DateTime?  @map("password_set_at") @db.Timestamptz(6)
  // Legacy / GoFunnel-specific extras ------------------------------------
  emailNormalized String?    @map("email_normalized") @db.Citext
  locale          String     @default("en-US")
  timezone        String     @default("UTC")
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  lastLoginIpHash String?    @map("last_login_ip_hash")
  status          UserStatus @default(active)
  isInternal      Boolean    @default(false) @map("is_internal")
  deactivatedAt   DateTime?  @map("deactivated_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)

  accounts Account[]
  sessions AuthSession[]

  ownedWorkspaces          Workspace[]             @relation("WorkspaceOwner")
  memberships              WorkspaceMember[]       @relation("WorkspaceMemberUser")
  inviterMemberships       WorkspaceMember[]       @relation("WorkspaceMemberInviter")
  removerMemberships       WorkspaceMember[]       @relation("WorkspaceMemberRemover")
  createdFunnels           Funnel[]                @relation("FunnelCreator")
  publishedVersions        FunnelVersion[]         @relation("FunnelVersionPublisher")
  hostedBookings           Booking[]               @relation("BookingHost")
  createdApiKeys           ApiKey[]                @relation("ApiKeyCreator")
  revokedApiKeys           ApiKey[]                @relation("ApiKeyRevoker")
  createdWebhooks          Webhook[]               @relation("WebhookCreator")
  createdAdCampaigns       AdCampaign[]            @relation("AdCampaignCreator")
  createdEmailSequences    EmailSequence[]         @relation("EmailSequenceCreator")
  createdSmsSequences      SmsSequence[]           @relation("SmsSequenceCreator")
  createdLeadMagnets       LeadMagnet[]            @relation("LeadMagnetCreator")
  createdAssets            Asset[]                 @relation("AssetCreator")
  createdAssetVersions     AssetVersion[]          @relation("AssetVersionCreator")
  connectedIntegrations    IntegrationConnection[] @relation("IntegrationConnector")
  disconnectedIntegrations IntegrationConnection[] @relation("IntegrationDisconnector")
  initiatedRefunds         Refund[]                @relation("RefundInitiator")
  auditActions             AuditLog[]              @relation("AuditActor")
  auditImpersonations      AuditLog[]              @relation("AuditImpersonator")
  publishedFunnels         PublishedFunnel[]       @relation("PublishedFunnelPublisher")
  createdShortLinks        ShortLink[]             @relation("ShortLinkCreator")

  @@unique([emailNormalized], map: "users_email_norm_unique")
  @@index([lastLoginAt(sort: Desc)], map: "users_last_login_idx")
  @@map("users")
}

// =====================================================================
// AUTH.JS / NEXT-AUTH adapter tables
// Standard schema from @auth/prisma-adapter — DO NOT rename columns.
// =====================================================================

model Account {
  id                String  @id @default(dbgenerated("'act_' || encode(gen_random_bytes(13), 'hex')"))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_idx")
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(dbgenerated("'ass_' || encode(gen_random_bytes(13), 'hex')"))
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "auth_sessions_user_idx")
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(6)

  @@id([identifier, token])
  @@unique([token])
  @@map("verification_tokens")
}

// =====================================================================
// WORKSPACES
// =====================================================================

model Workspace {
  id                String          @id
  slug              String          @db.Citext
  name              String
  ownerUserId       String          @map("owner_user_id")
  plan              String          @default("trial")
  status            WorkspaceStatus @default(active)
  vertical          String?
  region            String          @default("us-east-1")
  dataResidencyLock Boolean         @default(false) @map("data_residency_lock")
  brandColors       Json            @default("{}") @map("brand_colors") @db.JsonB
  featureFlags      Json            @default("{}") @map("feature_flags") @db.JsonB
  aiTrainingOptIn   Boolean         @default(false) @map("ai_training_opt_in")
  closedAt          DateTime?       @map("closed_at") @db.Timestamptz(6)
  closedReason      String?         @map("closed_reason")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?       @map("deleted_at") @db.Timestamptz(6)

  owner            User                    @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members          WorkspaceMember[]
  funnels          Funnel[]
  funnelVersions   FunnelVersion[]
  crmContacts      CrmContact[]
  leads            Lead[]
  bookings         Booking[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  payments         Payment[]
  refunds          Refund[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  assets           Asset[]
  assetVersions    AssetVersion[]
  integrations     IntegrationConnection[]
  revtryCalls      RevTryCall[]
  adCampaigns      AdCampaign[]
  emailSequences   EmailSequence[]
  smsSequences     SmsSequence[]
  leadMagnets      LeadMagnet[]
  publishedFunnels PublishedFunnel[]
  shortLinks       ShortLink[]
  customDomains    CustomDomain[]

  @@unique([slug], map: "workspaces_slug_unique")
  @@index([ownerUserId], map: "workspaces_owner_idx")
  @@index([region], map: "workspaces_region_idx")
  @@index([status], map: "workspaces_status_idx")
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  invitedBy   String?       @map("invited_by")
  invitedAt   DateTime?     @map("invited_at") @db.Timestamptz(6)
  joinedAt    DateTime?     @map("joined_at") @db.Timestamptz(6)
  removedAt   DateTime?     @map("removed_at") @db.Timestamptz(6)
  removedBy   String?       @map("removed_by")
  lastSeenAt  DateTime?     @map("last_seen_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter   User?     @relation("WorkspaceMemberInviter", fields: [invitedBy], references: [id], onDelete: SetNull)
  remover   User?     @relation("WorkspaceMemberRemover", fields: [removedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId], map: "wsm_workspace_idx")
  @@index([userId], map: "wsm_user_idx")
  @@map("workspace_members")
}

// =====================================================================
// FUNNELS
// =====================================================================

model Funnel {
  id               String       @id
  workspaceId      String       @map("workspace_id")
  name             String
  slug             String       @db.Citext
  status           FunnelStatus @default(draft)
  vertical         String?
  currentVersionId String?      @map("current_version_id")
  liveUrl          String?      @map("live_url")
  customDomainId   String?      @map("custom_domain_id")
  aiDisclosure     Json         @default("{\"enabled\": true}") @map("ai_disclosure") @db.JsonB
  createdBy        String       @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  archivedAt       DateTime?    @map("archived_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)

  workspace            Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator              User              @relation("FunnelCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  versions             FunnelVersion[]   @relation("FunnelVersions")
  currentVersion       FunnelVersion?    @relation("FunnelCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  leads                Lead[]
  bookings             Booking[]
  assets               Asset[]
  adCampaigns          AdCampaign[]
  emailSequences       EmailSequence[]
  smsSequences         SmsSequence[]
  leadMagnets          LeadMagnet[]
  publishedFunnels     PublishedFunnel[]
  shortLinks           ShortLink[]
  customDomainsDefault CustomDomain[]    @relation("CustomDomainDefaultFunnel")

  @@unique([workspaceId, slug], map: "funnels_workspace_slug_unique")
  @@index([workspaceId, status], map: "funnels_workspace_status_idx")
  @@index([workspaceId, createdAt(sort: Desc)], map: "funnels_workspace_created_idx")
  @@map("funnels")
}

model FunnelVersion {
  id              String                       @id
  workspaceId     String                       @map("workspace_id")
  funnelId        String                       @map("funnel_id")
  versionNumber   Int                          @map("version_number")
  generationId    String?                      @map("generation_id")
  source          String
  parentVersionId String?                      @map("parent_version_id")
  artifactHash    String                       @map("artifact_hash")
  bundleS3Uri     String                       @map("bundle_s3_uri")
  copyBlob        Json                         @map("copy_blob") @db.JsonB
  designBlob      Json                         @map("design_blob") @db.JsonB
  configBlob      Json                         @map("config_blob") @db.JsonB
  complianceBlob  Json                         @default("{}") @map("compliance_blob") @db.JsonB
  qualityScore    Decimal?                     @map("quality_score") @db.Decimal(5, 2)
  isPublished     Boolean                      @default(false) @map("is_published")
  publishedAt     DateTime?                    @map("published_at") @db.Timestamptz(6)
  publishedBy     String?                      @map("published_by")
  unpublishedAt   DateTime?                    @map("unpublished_at") @db.Timestamptz(6)
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel           Funnel            @relation("FunnelVersions", fields: [funnelId], references: [id], onDelete: Cascade)
  parent           FunnelVersion?    @relation("FunnelVersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  children         FunnelVersion[]   @relation("FunnelVersionParent")
  publisher        User?             @relation("FunnelVersionPublisher", fields: [publishedBy], references: [id], onDelete: SetNull)
  currentOnFunnel  Funnel[]          @relation("FunnelCurrentVersion")
  leads            Lead[]
  publishedFunnels PublishedFunnel[]

  @@unique([funnelId, versionNumber], map: "fv_funnel_version_unique")
  @@index([workspaceId], map: "fv_workspace_idx")
  @@index([generationId], map: "fv_generation_idx")
  @@index([funnelId, isPublished], map: "fv_published_idx")
  @@map("funnel_versions")
}

// =====================================================================
// CRM / LEADS / BOOKINGS
// =====================================================================

model CrmContact {
  id              String                       @id
  workspaceId     String                       @map("workspace_id")
  emailNormalized String?                      @map("email_normalized") @db.Citext
  emailSha256     String?                      @map("email_sha256")
  phoneE164       String?                      @map("phone_e164")
  phoneSha256     String?                      @map("phone_sha256")
  fullName        String?                      @map("full_name")
  firstName       String?                      @map("first_name")
  lastName        String?                      @map("last_name")
  company         String?
  customFields    Json                         @default("{}") @map("custom_fields") @db.JsonB
  tags            String[]                     @default([])
  consent         Json                         @default("{}") @db.JsonB
  doNotContact    Boolean                      @default(false) @map("do_not_contact")
  primarySource   String?                      @map("primary_source")
  firstSeenAt     DateTime                     @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastActivityAt  DateTime?                    @map("last_activity_at") @db.Timestamptz(6)
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?                    @map("deleted_at") @db.Timestamptz(6)
  tombstone       Boolean                      @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@index([workspaceId, lastActivityAt(sort: Desc)], map: "crm_workspace_last_activity_idx")
  @@map("crm_contacts")
}

model Lead {
  id                    String                       @id
  workspaceId           String                       @map("workspace_id")
  funnelId              String                       @map("funnel_id")
  funnelVersionId       String                       @map("funnel_version_id")
  crmContactId          String?                      @map("crm_contact_id")
  status                LeadStatus                   @default(new)
  score                 Decimal?                     @db.Decimal(5, 2)
  scoreBand             String?                      @map("score_band")
  scoreModelVersion     String?                      @map("score_model_version")
  captureSource         String                       @map("capture_source")
  captureUrl            String?                      @map("capture_url")
  utm                   Json                         @default("{}") @db.JsonB
  ipHash                String?                      @map("ip_hash")
  geoCountry            String?                      @map("geo_country")
  geoRegion             String?                      @map("geo_region")
  consentId             String?                      @map("consent_id")
  attributionBlob       Json                         @default("{}") @map("attribution_blob") @db.JsonB
  firstContactAt        DateTime?                    @map("first_contact_at") @db.Timestamptz(6)
  lastContactAt         DateTime?                    @map("last_contact_at") @db.Timestamptz(6)
  qualifiedAt           DateTime?                    @map("qualified_at") @db.Timestamptz(6)
  disqualifiedAt        DateTime?                    @map("disqualified_at") @db.Timestamptz(6)
  disqualifiedReason    String?                      @map("disqualified_reason")
  convertedAt           DateTime?                    @map("converted_at") @db.Timestamptz(6)
  conversionValueMicros BigInt?                      @map("conversion_value_micros")
  conversionCurrency    String?                      @map("conversion_currency") @db.Char(3)
  embedding             Unsupported("vector(1536)")?
  createdAt             DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?                    @map("deleted_at") @db.Timestamptz(6)

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel        Funnel        @relation(fields: [funnelId], references: [id], onDelete: Restrict)
  funnelVersion FunnelVersion @relation(fields: [funnelVersionId], references: [id], onDelete: Restrict)
  crmContact    CrmContact?   @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  bookings      Booking[]
  revtryCalls   RevTryCall[]

  @@index([workspaceId, status], map: "leads_workspace_status_idx")
  @@index([funnelId, createdAt(sort: Desc)], map: "leads_funnel_created_idx")
  @@index([workspaceId, score(sort: Desc)], map: "leads_score_idx")
  @@index([crmContactId], map: "leads_crm_contact_idx")
  @@index([consentId], map: "leads_consent_idx")
  @@index([workspaceId, createdAt(sort: Desc)], map: "leads_workspace_created_idx")
  @@map("leads")
}

model Booking {
  id               String        @id
  workspaceId      String        @map("workspace_id")
  leadId           String        @map("lead_id")
  funnelId         String        @map("funnel_id")
  hostUserId       String?       @map("host_user_id")
  externalCalendar String?       @map("external_calendar")
  externalEventId  String?       @map("external_event_id")
  scheduledFor     DateTime      @map("scheduled_for") @db.Timestamptz(6)
  durationMinutes  Int           @default(30) @map("duration_minutes")
  timezone         String        @default("UTC")
  meetingUrl       String?       @map("meeting_url")
  status           BookingStatus @default(confirmed)
  canceledAt       DateTime?     @map("canceled_at") @db.Timestamptz(6)
  canceledBy       String?       @map("canceled_by")
  cancelReason     String?       @map("cancel_reason")
  notesHash        String?       @map("notes_hash")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  funnel    Funnel    @relation(fields: [funnelId], references: [id], onDelete: Restrict)
  host      User?     @relation("BookingHost", fields: [hostUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, scheduledFor], map: "bookings_workspace_scheduled_idx")
  @@index([leadId], map: "bookings_lead_idx")
  @@index([hostUserId], map: "bookings_host_idx")
  @@map("bookings")
}

// =====================================================================
// BILLING
// =====================================================================

model Subscription {
  id                     String             @id
  workspaceId            String             @map("workspace_id")
  plan                   String
  status                 SubscriptionStatus @default(trialing)
  externalProcessor      String             @default("stripe") @map("external_processor")
  externalSubscriptionId String?            @map("external_subscription_id")
  externalCustomerId     String?            @map("external_customer_id")
  currentPeriodStart     DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd       DateTime?          @map("current_period_end") @db.Timestamptz(6)
  trialEndsAt            DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  canceledAt             DateTime?          @map("canceled_at") @db.Timestamptz(6)
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  cancellationReason     String?            @map("cancellation_reason")
  pausedAt               DateTime?          @map("paused_at") @db.Timestamptz(6)
  resumeAt               DateTime?          @map("resume_at") @db.Timestamptz(6)
  unitAmountMicros       BigInt?            @map("unit_amount_micros")
  currency               String             @default("USD") @db.Char(3)
  quantity               Int                @default(1)
  metadata               Json               @default("{}") @db.JsonB
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  invoices  Invoice[]

  @@index([workspaceId, status], map: "sub_workspace_status_idx")
  @@map("subscriptions")
}

model Invoice {
  id                   String        @id
  workspaceId          String        @map("workspace_id")
  subscriptionId       String?       @map("subscription_id")
  externalProcessor    String        @default("stripe") @map("external_processor")
  externalInvoiceId    String?       @map("external_invoice_id")
  status               InvoiceStatus @default(draft)
  number               String?
  amountDueMicros      BigInt        @map("amount_due_micros")
  amountPaidMicros     BigInt        @default(0) @map("amount_paid_micros")
  amountRefundedMicros BigInt        @default(0) @map("amount_refunded_micros")
  taxMicros            BigInt        @default(0) @map("tax_micros")
  currency             String        @db.Char(3)
  periodStart          DateTime?     @map("period_start") @db.Timestamptz(6)
  periodEnd            DateTime?     @map("period_end") @db.Timestamptz(6)
  dueAt                DateTime?     @map("due_at") @db.Timestamptz(6)
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz(6)
  voidedAt             DateTime?     @map("voided_at") @db.Timestamptz(6)
  hostedUrl            String?       @map("hosted_url")
  pdfUrl               String?       @map("pdf_url")
  lineItems            Json          @default("[]") @map("line_items") @db.JsonB
  metadata             Json          @default("{}") @db.JsonB
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@index([workspaceId, status], map: "inv_workspace_status_idx")
  @@index([periodStart, periodEnd], map: "inv_period_idx")
  @@map("invoices")
}

model Payment {
  id                String        @id
  workspaceId       String        @map("workspace_id")
  invoiceId         String?       @map("invoice_id")
  externalProcessor String        @default("stripe") @map("external_processor")
