// =====================================================================
// DEPLOYMENT — published funnels, short links, custom domains
// =====================================================================

/// Immutable per-publish snapshot. One row per (funnel_id, version) pair.
/// The renderer reads from this table — NOT from funnels/funnel_versions —
/// when serving the hot path, so unpublishing is one UPDATE away from
/// taking a site offline without losing the snapshot.
model PublishedFunnel {
  id              String                @id @default(dbgenerated("'pub_' || encode(gen_random_bytes(12), 'hex')"))
  workspaceId     String                @map("workspace_id")
  funnelId        String                @map("funnel_id")
  funnelVersionId String                @map("funnel_version_id")
  /// The chosen subdomain label, e.g. 'solar-x9k' → solar-x9k.gofunnelai.com.
  slug            String                @db.Citext
  subdomainUrl    String                @map("subdomain_url")
  /// Optional pretty CNAMEd hostname. NULL until activated by the
  /// custom-domain workflow. Multiple PublishedFunnel rows can reference the
  /// same CustomDomain over the lifetime of that domain.
  customDomain    String?               @map("custom_domain")
  status          PublishedFunnelStatus @default(active)
  /// Immutable snapshot of the funnel JSON at publish time.
  snapshot        Json                  @db.JsonB
  version         Int                   @default(1)
  publishedAt     DateTime              @default(now()) @map("published_at") @db.Timestamptz(6)
  publishedBy     String?               @map("published_by")
  pausedAt        DateTime?             @map("paused_at") @db.Timestamptz(6)
  archivedAt      DateTime?             @map("archived_at") @db.Timestamptz(6)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel        Funnel        @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  funnelVersion FunnelVersion @relation(fields: [funnelVersionId], references: [id], onDelete: Restrict)
  publisher     User?         @relation("PublishedFunnelPublisher", fields: [publishedBy], references: [id], onDelete: SetNull)
  shortLinks    ShortLink[]

  @@unique([slug], map: "published_funnels_slug_unique")
  @@unique([funnelId, version], map: "published_funnels_funnel_version_unique")
  @@index([workspaceId], map: "published_funnels_workspace_idx")
  @@index([funnelId, status], map: "published_funnels_funnel_status_idx")
  @@index([customDomain], map: "published_funnels_custom_domain_idx")
  @@map("published_funnels")
}

/// gofnl.co/[6chars] → published funnel URL. Auto-generated on publish,
/// vanity codes reserved for Growth+ tier.
model ShortLink {
  id            String    @id @default(dbgenerated("'sl_' || encode(gen_random_bytes(8), 'hex')"))
  /// 6-character base32 code OR vanity slug (≤32 chars).
  code          String    @db.Citext
  targetUrl     String    @map("target_url")
  funnelId      String?   @map("funnel_id")
  publishedId   String?   @map("published_id")
  workspaceId   String    @map("workspace_id")
  vanity        Boolean   @default(false)
  clickCount    BigInt    @default(0) @map("click_count")
  lastClickedAt DateTime? @map("last_clicked_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel    Funnel?          @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  published PublishedFunnel? @relation(fields: [publishedId], references: [id], onDelete: SetNull)
  creator   User?            @relation("ShortLinkCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([code], map: "short_links_code_unique")
  @@index([workspaceId], map: "short_links_workspace_idx")
  @@index([funnelId], map: "short_links_funnel_idx")
  @@map("short_links")
}

/// Customer-CNAMEd hostnames. Cloudflare for SaaS owns the cert; we own
/// the verification ledger + state machine. Workspace can have many
/// (root + www, region-specific, etc).
model CustomDomain {
  id                   String             @id @default(dbgenerated("'cd_' || encode(gen_random_bytes(12), 'hex')"))
  workspaceId          String             @map("workspace_id")
  /// Lowercased, no scheme, no path. e.g. 'getfreequote.com'.
  hostname             String             @db.Citext
  status               CustomDomainStatus @default(pending)
  /// Random TXT record value the customer copies into DNS for ownership proof.
  verificationToken    String             @map("verification_token")
  /// Cloudflare for SaaS custom-hostname id, set after the API call lands.
  cloudflareHostnameId String?            @map("cloudflare_hostname_id")
  sslStatus            SslStatus          @default(pending_validation) @map("ssl_status")
  /// Optional pointer to the funnel this domain serves by default. If null,
  /// the workspace must supply path-based routing.
  defaultFunnelId      String?            @map("default_funnel_id")
  lastCheckedAt        DateTime?          @map("last_checked_at") @db.Timestamptz(6)
  verifiedAt           DateTime?          @map("verified_at") @db.Timestamptz(6)
  activatedAt          DateTime?          @map("activated_at") @db.Timestamptz(6)
  failureReason        String?            @map("failure_reason")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?          @map("deleted_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  defaultFunnel Funnel?   @relation("CustomDomainDefaultFunnel", fields: [defaultFunnelId], references: [id], onDelete: SetNull)

  @@unique([hostname], map: "custom_domains_hostname_unique")
  @@index([workspaceId], map: "custom_domains_workspace_idx")
  @@index([status], map: "custom_domains_status_idx")
  @@map("custom_domains")
}

