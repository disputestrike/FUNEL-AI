# pnpm config for GoFunnelAI
#
# Hoist Prisma + Next.js + their plugins to top-level node_modules so:
#   - node_modules/.prisma actually exists (Prisma client generated here)
#   - node_modules/@prisma resolves at runtime without symlink chasing
#   - Dockerfile COPY commands hit real paths instead of pnpm's .pnpm/* store
#   - Next.js standalone tracing finds everything it expects
#
# Without this, the runtime Docker stage fails with:
#   "/app/node_modules/.prisma": not found
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=@next/*
public-hoist-pattern[]=next
public-hoist-pattern[]=sharp

# Don't fail install on peer dep warnings (next-auth + @auth/core + simplewebauthn).
strict-peer-dependencies=false

# Keep lockfile + use exact resolutions across deploys.
frozen-lockfile=true
