// GoFunnelAI Shopify app â€” persistent state.
//
// Two tables:
//   - Session: managed by @shopify/shopify-app-session-storage-prisma
//   - FunnelLink: our own â€” maps a shop domain to a GoFunnelAI workspace token

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model FunnelLink {
  shop           String   @id
  workspaceId    String
  workspaceName  String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  defaultFunnelId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DiscountIssue {
  id          String   @id @default(cuid())
  shop        String
  funnelId    String
  leadEmail   String
  priceRuleId String
  code        String
  createdAt   DateTime @default(now())

  @@index([shop, leadEmail])
}
