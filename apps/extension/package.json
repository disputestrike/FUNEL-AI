{
  "name": "@funnel/extension",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI browser extension — audit any page, save funnels for inspiration, import competitor funnels, lead inbox in the side panel.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build --target=chrome-mv3 && plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@funnel/sdk": "workspace:*",
    "@funnel/ui": "workspace:*",
    "@plasmohq/storage": "^1.10.0",
    "@plasmohq/messaging": "^0.6.2",
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@testing-library/react": "^14.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "GoFunnelAI — Audit, Save, Import Funnels",
    "permissions": [
      "activeTab",
      "storage",
      "contextMenus",
      "scripting",
      "sidePanel",
      "identity"
    ],
    "host_permissions": [
      "https://*.gofunnelai.com/*",
      "https://*.clickfunnels.com/*",
      "https://*.gohighlevel.com/*",
      "https://*.leadpages.com/*",
      "https://*.unbounce.com/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "action": {
      "default_title": "GoFunnelAI",
      "default_popup": "popup.html"
    },
    "background": {
      "service_worker": "background.js",
      "type": "module"
    }
  }
}
