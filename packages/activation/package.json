{
  "name": "@funnel/activation",
  "version": "0.1.0",
  "private": true,
  "description": "Customer Success Activation Framework — Success Path, lifecycle orchestrator, intervention triggers, concierge playbook. See docs/06a-customer-success-activation-framework.md.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./success-path": {
      "types": "./dist/success-path.d.ts",
      "import": "./dist/success-path.js"
    },
    "./lifecycle-orchestrator": {
      "types": "./dist/lifecycle-orchestrator.d.ts",
      "import": "./dist/lifecycle-orchestrator.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler.d.ts",
      "import": "./dist/scheduler.js"
    },
    "./cohort": {
      "types": "./dist/cohort.d.ts",
      "import": "./dist/cohort.js"
    },
    "./weekly-digest": {
      "types": "./dist/weekly-digest.d.ts",
      "import": "./dist/weekly-digest.js"
    },
    "./opt-out": {
      "types": "./dist/opt-out.d.ts",
      "import": "./dist/opt-out.js"
    },
    "./save-offers": {
      "types": "./dist/save-offers.d.ts",
      "import": "./dist/save-offers.js"
    },
    "./concierge-playbook": {
      "types": "./dist/concierge-playbook.d.ts",
      "import": "./dist/concierge-playbook.js"
    },
    "./triggers": {
      "types": "./dist/triggers/index.d.ts",
      "import": "./dist/triggers/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(no linter configured)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@funnel/db": "workspace:*",
    "@funnel/email": "workspace:*",
    "@funnel/events": "workspace:*",
    "@funnel/notifications": "workspace:*",
    "@funnel/revtry": "workspace:*",
    "@funnel/shared": "workspace:*",
    "ioredis": "^5.4.1",
    "pg-boss": "^10.1.5",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
