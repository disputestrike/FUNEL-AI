exports[`Audience Targeting agent (L2) > builds a Meta audience for solar with locations, age, interests, and exclusions 1`] = `
{
  "estimatedReachBand": "moderate",
  "kbPackId": "solar-us-en",
  "name": "Solar installation — meta — Primary",
  "personaDescription": "Homeowners aged 35-65 with rising power bills in sun-heavy states",
  "platform": "meta",
  "secondaryPersonaDescription": "Co-decision-making spouse or partner reviewing the savings plan before any consult.",
  "targeting": {
    "params": {
      "age": {
        "max": 70,
        "min": 35,
      },
      "behaviors": [
        "Likely homeowner",
        "Recently moved",
        "High utility bill mentioned",
        "Engaged with EV content",
        "Engaged with energy rebate content",
      ],
      "exclusions": [
        "Renters",
        "Solar industry employees",
        "Recently quoted solar",
      ],
      "genders": "all",
      "interests": [
        "Home improvement",
        "Renewable energy",
        "Electric vehicles",
        "Smart home",
        "Energy efficiency",
        "Tesla",
        "Real estate ownership",
      ],
      "locations": [
        "US",
      ],
      "lookalikeSource": "ca_solar_installs_2026",
    },
    "platform": "meta",
  },
}
`;

