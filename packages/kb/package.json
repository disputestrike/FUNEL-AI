{
  "name": "@funnel/kb",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI Industry Knowledge Base â€” 30 vertical packs Ã— geo Ã— language, nightly-refreshed, pgvector-retrieved at generation time. The core moat.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./retrieval": {
      "types": "./dist/retrieval.d.ts",
      "import": "./dist/retrieval.js"
    },
    "./ingestion": {
      "types": "./dist/ingestion/index.d.ts",
      "import": "./dist/ingestion/index.js"
    }
  },
  "files": [
    "dist",
    "src/packs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(no linter configured)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:nightly": "tsx src/ingestion/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@funnel/db": "workspace:*",
