model RateLimit {
  /// e.g. "ip:1.2.3.4", "domain:example.com"
  scope       String
  /// e.g. "2026-05-26T14" (hourly) or "2026-05-26" (daily).
  windowKey   String   @map("window_key")
  count       Int      @default(0)
  windowStart DateTime @default(now()) @map("window_start") @db.Timestamptz(6)

  @@id([scope, windowKey])
  @@map("rate_limits")
}

model AgentRun {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auditId         String   @map("audit_id") @db.Uuid
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  agentName       String   @map("agent_name")
  model           String
  inputTokens     Int?     @map("input_tokens")
  outputTokens    Int?     @map("output_tokens")
  cacheReadTokens Int?     @map("cache_read_tokens")
  durationMs      Int?     @map("duration_ms")
  ok              Boolean
  error           String?
  /// Stored 30 days then nulled.
  rawOutput       String?  @map("raw_output")
  /// Parsed agent JSON output. Kept indefinitely for analytics.
  output          Json?    @db.JsonB
  costCents       Float?   @map("cost_cents")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([auditId], map: "agent_runs_audit_idx")
  @@index([agentName], map: "agent_runs_name_idx")
  @@map("agent_runs")
}

model CostGovernor {
  day                DateTime @id @db.Date
  spendCents         Int      @default(0) @map("spend_cents")
  auditsCompleted    Int      @default(0) @map("audits_completed")
  previewsGenerated  Int      @default(0) @map("previews_generated")
  /// 'normal' | 'degraded' | 'queue' | 'cutoff'
  mode               String   @default("normal")

  @@map("cost_governor")
}
