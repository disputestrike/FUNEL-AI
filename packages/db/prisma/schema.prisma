// =====================================================================
// FUNNEL GRADER (Week-2 Trojan Horse â€” public free audit at /grade).
// =====================================================================
// These tables are scoped to the grader app but live in the canonical
// Prisma schema so `@funnel/db` is the single source of truth.
// See: docs/01-funnel-grader-build-spec.md Â§8.

enum GraderAuditStatus {
  queued
  rendering
  scoring
  done
  failed

  @@map("grader_audit_status")
}

enum GraderConfidence {
  high
  medium
  low

  @@map("grader_confidence")
}

model Audit {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url             String
  urlHostname     String             @map("url_hostname")
  /// sha256 of normalized URL â€” used for 24h cache lookup.
  urlHash         String             @map("url_hash")
  requesterIp     String?            @map("requester_ip") @db.Inet
  requesterUa     String?            @map("requester_ua")

  status          GraderAuditStatus  @default(queued)
  failureReason   String?            @map("failure_reason")

  scoreOverall    Int?               @map("score_overall")
  scoreGrade      String?            @map("score_grade")
  /// {hook:47, form:72, trust:55, speed:62, compliance:85}
  subscores       Json?
  critique        String?
  /// Array of Improvement objects (see @funnel/shared types).
  improvements    Json?
  /// Per-agent run meta: {model, tokens, ms, ok, error}
  agentRunsMeta   Json?              @map("agent_runs_meta")
  confidence      GraderConfidence?
  degradedAgents  String[]           @map("degraded_agents")

  screenshotR2Key String?            @map("screenshot_r2_key")
  pdfR2Key        String?            @map("pdf_r2_key")
  previewR2Key    String?            @map("preview_r2_key")
  ogR2Key         String?            @map("og_r2_key")

  /// LLM + render cost in cents (integer math).
  costCents       Int?               @map("cost_cents")

  isPublic        Boolean            @default(false) @map("is_public")

  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt     DateTime?          @map("completed_at") @db.Timestamptz(6)

  shareCode       ShareCode?
  emailCaptures   EmailCapture[]
  waitlistEntries Waitlist[]
  agentRuns       AgentRun[]

  @@index([urlHash], map: "audits_url_hash_idx")
  @@index([urlHostname], map: "audits_hostname_idx")
  @@index([createdAt(sort: Desc)], map: "audits_created_idx")
  @@index([requesterIp, createdAt(sort: Desc)], map: "audits_requester_ip_idx")
  @@map("audits")
}

model ShareCode {
  /// 6-char base32 code (Crockford alphabet, lowercase).
  code        String   @id
  auditId     String   @unique @map("audit_id") @db.Uuid
  audit       Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  viewCount   Int      @default(0) @map("view_count")
  lastViewed  DateTime? @map("last_viewed") @db.Timestamptz(6)

  @@map("share_codes")
}

model EmailCapture {
