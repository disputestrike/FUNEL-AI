// =====================================================================
// AUDIT + EVENTS
// Both are PARTITIONED BY RANGE(occurred_at); see migration.sql.
// =====================================================================

model AuditLog {
  id                 String   @default("")
  workspaceId        String?  @map("workspace_id")
  actorUserId        String?  @map("actor_user_id")
  impersonatorUserId String?  @map("impersonator_user_id")
  action             String
  subjectType        String   @map("subject_type")
  subjectId          String   @map("subject_id")
  beforeBlob         Json?    @map("before_blob") @db.JsonB
  afterBlob          Json?    @map("after_blob") @db.JsonB
  diff               Json?    @db.JsonB
  ipHash             String?  @map("ip_hash")
  userAgent          String?  @map("user_agent")
  requestId          String?  @map("request_id")
  traceId            String?  @map("trace_id")
  reason             String?
  piiTier            PiiTier  @default(P1) @map("pii_tier")
  occurredAt         DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  actor        User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  impersonator User? @relation("AuditImpersonator", fields: [impersonatorUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([id, occurredAt])
  @@index([workspaceId, occurredAt(sort: Desc)], map: "audit_workspace_time_idx")
  @@index([actorUserId, occurredAt(sort: Desc)], map: "audit_actor_time_idx")
  @@index([subjectType, subjectId], map: "audit_subject_idx")
  @@map("audit_log")
}

model EventLog {
  eventId            String   @map("event_id")
  eventName          String   @map("event_name")
  eventFamily        String   @map("event_family")
  schemaVersion      Int      @map("schema_version")
  workspaceId        String?  @map("workspace_id")
  actorType          String   @map("actor_type")
  actorUserId        String?  @map("actor_user_id")
  agentId            String?  @map("agent_id")
  impersonatorUserId String?  @map("impersonator_user_id")
  subjectType        String?  @map("subject_type")
  subjectId          String?  @map("subject_id")
  piiTier            PiiTier  @map("pii_tier")
  properties         Json     @db.JsonB
  context            Json     @default("{}") @db.JsonB
  consent            Json     @default("{}") @db.JsonB
  producer           Json     @db.JsonB
  occurredAt         DateTime @map("occurred_at") @db.Timestamptz(6)
  receivedAt         DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@id([eventId, occurredAt])
  @@index([workspaceId, eventName, occurredAt(sort: Desc)], map: "el_workspace_name_time_idx")
  @@index([eventFamily, occurredAt(sort: Desc)], map: "el_family_time_idx")
  @@index([subjectType, subjectId], map: "el_subject_idx")
  @@map("event_log")
}

