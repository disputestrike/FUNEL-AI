# --- MyFunnelAI database connection ---
# Pooled connection (PgBouncer/Supavisor) â€” used by application runtime queries.
# Use ?pgbouncer=true to disable prepared statements when behind PgBouncer in transaction mode.
DATABASE_URL="postgresql://funnel:funnel@localhost:5432/funnel?schema=public&pgbouncer=true&connection_limit=20"

# Direct connection â€” used by Prisma Migrate, introspection, and the seed script.
# Must point at the real Postgres (NOT the pooler).
DIRECT_DATABASE_URL="postgresql://funnel:funnel@localhost:5432/funnel?schema=public"

# Optional. Used by withWorkspaceContext when no caller-provided value is set.
# Useful for local development scripts that operate on a fixed workspace.
DEFAULT_WORKSPACE_ID=""

# Set to "1" to log every query (very chatty â€” dev only).
PRISMA_QUERY_LOG="0"

# Used by the seed script.
SEED_DETERMINISTIC="1"
