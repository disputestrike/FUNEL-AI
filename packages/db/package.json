{
  "name": "@funnel/db",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI canonical Postgres + Prisma database package (schemas, RLS, seed, types).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./rls": {
      "types": "./dist/rls.d.ts",
      "import": "./dist/rls.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./client": {
      "types": "./node_modules/.prisma/client/index.d.ts",
      "import": "./node_modules/.prisma/client/index.js",
      "default": "./node_modules/.prisma/client/index.js"
    }
  },
  "files": [
    "dist",
    "prisma",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo node_modules/.prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:deploy": "bash scripts/migrate-on-deploy.sh",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@prisma/client": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
