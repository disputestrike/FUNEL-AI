{
  "name": "@funnel/notifications",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI multi-channel notification engine — in-app, email (Resend), push, SMS (SignalWire), Slack, Discord. Per-user prefs, owner overrides, digest, retry+DLQ, audit log.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@funnel/db": "workspace:*",
    "@funnel/email": "workspace:*",
    "@funnel/events": "workspace:*",
    "@funnel/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
