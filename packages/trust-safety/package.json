{
  "name": "@funnel/trust-safety",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI Trust & Safety: 10 risk-class classifiers (phishing, fake business, illegal offers, affiliate fraud, SMS spam, voice consent, ad-policy abuse, payment fraud, KYC, domain reputation), suspension workflow, transparency report, ts.events.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(no linter configured)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@funnel/db": "workspace:*",
    "@funnel/events": "workspace:*",
    "@funnel/integrations": "workspace:*",
    "@funnel/shared": "workspace:*",
    "axios": "^1.7.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
