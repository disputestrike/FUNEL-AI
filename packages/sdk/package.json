{
  "name": "@funnel/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the GoFunnelAI REST API.",
  "license": "Apache-2.0",
  "homepage": "https://developers.gofunnelai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/gofunnelai/funnel-ai",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js",
      "require": "./dist/webhooks.cjs"
    }
  },
  "files": ["dist", "README.md", "openapi.json"],
  "scripts": {
    "build": "tsup src/index.ts src/webhooks.ts --format esm,cjs --dts --clean",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ofetch": "^1.4.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.8"
  },
  "engines": { "node": ">=18.0.0" },
  "keywords": ["funnel", "gofunnelai.com", "sdk", "rest", "api", "leads", "crm", "ai-funnels"],
  "publishConfig": { "access": "public" }
}
