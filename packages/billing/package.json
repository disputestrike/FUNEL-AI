{
  "name": "@funnel/billing",
  "version": "0.1.0",
  "private": true,
  "description": "GoFunnelAI billing package — PayPal (primary), Stripe (secondary), subscription lifecycle, dunning, refunds, invoices.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./paypal": {
      "types": "./dist/paypal/index.d.ts",
      "import": "./dist/paypal/index.js"
    },
    "./stripe": {
      "types": "./dist/stripe/index.d.ts",
      "import": "./dist/stripe/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo \"(no linter configured)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@funnel/db": "workspace:*",
    "@funnel/email": "workspace:*",
    "@funnel/events": "workspace:*",
    "@funnel/shared": "workspace:*",
    "@paypal/paypal-server-sdk": "^0.6.1",
    "@react-pdf/renderer": "^4.0.0",
    "react": "^18.3.1",
    "stripe": "^17.4.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@funnel/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
